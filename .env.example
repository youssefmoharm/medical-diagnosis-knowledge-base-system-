# Flask Configuration
FLASK_ENV=production
DEBUG=False

# Server Configuration
PORT=5000

# CORS Configuration (optional - restrict to your domain)
ALLOWED_ORIGINS=http://localhost:5000,https://your-domain.com

# Security (generate with: python -c "import secrets; print(secrets.token_hex(16))")
SECRET_KEY=your-secret-key-here

# Logging
LOG_LEVEL=INFO
